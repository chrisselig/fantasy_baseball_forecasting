# Copy this file to .env for local development.
# NEVER commit .env — it is gitignored.

# ── MotherDuck ────────────────────────────────────────────────────────────────
# Required by: Shiny app, GitHub Actions pipeline
# Get from: app.motherduck.com → Settings → Access Tokens
MOTHERDUCK_TOKEN=your_motherduck_token_here

# ── Yahoo Fantasy Sports API ──────────────────────────────────────────────────
# Required by: GitHub Actions pipeline ONLY (not the Shiny app)
# Get consumer key/secret from: developer.yahoo.com → My Apps
# Get access/refresh tokens by running: python scripts/yahoo_auth.py
YAHOO_CONSUMER_KEY=your_consumer_key_here
YAHOO_CONSUMER_SECRET=your_consumer_secret_here
YAHOO_ACCESS_TOKEN=generated_by_yahoo_auth_script
YAHOO_REFRESH_TOKEN=generated_by_yahoo_auth_script
